# ============================================================
# Supabase Configuration
# ============================================================
# 1. Go to https://supabase.com and sign in (free account)
# 2. Create a new project
# 3. Go to: Project Settings → API
# 4. Copy the values below:
#
#   NEXT_PUBLIC_SUPABASE_URL
#     → copy from "Project URL"
#
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#     → copy from "Project API keys"
#     → Supabase may label this key as "anon public" or
#       "PUBLISHABLE_DEFAULT_KEY" depending on the dashboard version.
#       They are the same key — paste whichever value you see.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# These values are safe to expose in the browser.
# The NEXT_PUBLIC_ prefix is intentional.
# Access is controlled by Supabase Row Level Security policies.
# ============================================================
